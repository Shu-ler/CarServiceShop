#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Процедура УстановитьПометкиСписка(Источник, Приемник, ИмяПоля)

	Для Каждого Эл Из Источник Цикл
		НайденЭлемент = Приемник.НайтиПоЗначению(Эл[ИмяПоля]);
		Если НайденЭлемент <> Неопределено Тогда
			НайденЭлемент.Пометка = Истина;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ВыбранныеВСписке(Список)

	Результат = Новый Массив;

	Для Каждого Эл Из Список Цикл
		Если Эл.Пометка Тогда
			Результат.Добавить(Эл.Значение);
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ОчиститьЗависимыеТаблицы()
	СписокАгрегаты.Очистить();
	СписокКузова.Очистить();
	СписокКомплектации.Очистить();
КонецПроцедуры

&НаСервереБезКонтекста
Функция МодельПриИзмененииНаСервере(Модель)
	Поколения = Справочники.АСМ_Модели.Поколения(Модель);
	Возврат Поколения;
КонецФункции

&НаСервере
Процедура ОбновитьСпискиПоПоколению(Выбрано = Истина)

	Поколения = Новый Массив;

	Для Каждого Эл Из СписокПоколения Цикл
		Если Эл.Пометка Тогда
			Поколения.Добавить(Эл.Значение);
		КонецЕсли;
	КонецЦикла;

	ОпцииОтбора = Справочники.АСМ_Поколения.ОпцииОтбора(Поколения);

	ТаблицаАгрегаты.Загрузить(ОпцииОтбора.Агрегаты);

	СписокКузова.Очистить();
	Для Каждого Эл Из ОпцииОтбора.ТипыКузовов Цикл
		СписокКузова.Добавить(Эл.Расшифровка, Эл.Расшифровка, Выбрано);
	КонецЦикла;

	СписокАгрегаты.Очистить();
	Для Каждого Эл Из ОпцииОтбора.Агрегаты Цикл
		СписокАгрегаты.Добавить(Эл.Расшифровка, Эл.Расшифровка, Выбрано);
	КонецЦикла;

	СписокКомплектации.Очистить();
	Для Каждого Эл Из ОпцииОтбора.Комплектации Цикл
		СписокКомплектации.Добавить(Эл.Наименование, Эл.Наименование, Выбрано);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура СписокАгрегатыПометкаПриИзменении(Элемент)
	Индекс = Элементы.СписокАгрегаты.ТекущаяСтрока;
	ТекущееЗначение = Элементы.СписокАгрегаты.ТекущиеДанные.Значение;

	Нечто = ТаблицаАгрегаты.НайтиСтроки(Новый Структура("Расшифровка", ТекущееЗначение));

	Нечто[0].Совместимо = Не Нечто[0].Совместимо;

КонецПроцедуры
#КонецОбласти