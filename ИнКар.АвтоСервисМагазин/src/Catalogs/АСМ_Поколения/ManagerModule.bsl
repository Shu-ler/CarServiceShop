// Возвращает данные модификаций и комплектаций
// 
// Параметры:
//  Ссылка - СправочникСсылка.АСМ_Поколения - Поколение
// 
// Возвращаемое значение:
//  Структура - Опции отбора:
// * ДвигателиТрансмиссии - ТаблицаЗначений - Объем и мощность двигателя, привод, тип трансмиссии
// * ТипыКузовов - ТаблицаЗначений - Типы кузовов, количество дверей
// * Комплектации - ТаблицаЗначений - Комплектации
Функция ОпцииОтбора(Ссылка) Экспорт

	ОпцииОтбора = Новый Структура;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Поколение", Ссылка);
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	АСМ_Модификации.ТипТоплива КАК ТипТоплива,
				   |	АСМ_Модификации.ТипПривода КАК ТипПривода,
				   |	АСМ_Модификации.ТипТрансмиссии КАК ТипТрансмиссии,
				   |	АСМ_Модификации.Мощность КАК Мощность,
				   |	АСМ_Модификации.РабочийОбъем КАК РабочийОбъем,
				   |	ИСТИНА КАК Совместимо,
				   |	АСМ_Модификации.ТипПривода.Наименование + "", "" + АСМ_Модификации.ТипТрансмиссии.Наименование + "", "" +
				   |		АСМ_Модификации.ТипТоплива.Наименование + "" ("" + АСМ_Модификации.РабочийОбъем.Наименование + ""л/"" +
				   |		АСМ_Модификации.Мощность.Наименование + ""л.с.)"" КАК Расшифровка
				   |ИЗ
				   |	Справочник.АСМ_Модификации КАК АСМ_Модификации
				   |ГДЕ
				   |	АСМ_Модификации.Поколение В (&Поколение)
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	АСМ_Модификации.ТипКузова КАК ТипКузова,
				   |	АСМ_Модификации.КоличествоДверей КАК КоличествоДверей,
				   |	ИСТИНА КАК Совместимо,
				   |	АСМ_Модификации.ТипКузова.Наименование + "" ("" + АСМ_Модификации.КоличествоДверей.Наименование + "" дв.)"" КАК
				   |		Расшифровка
				   |ИЗ
				   |	Справочник.АСМ_Модификации КАК АСМ_Модификации
				   |ГДЕ
				   |	АСМ_Модификации.Поколение В (&Поколение)
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	ИСТИНА КАК Совместимо,
				   |	АСМ_МодификацииКомплектации.Комплектация.Наименование КАК Наименование
				   |ИЗ
				   |	Справочник.АСМ_Модификации.Комплектации КАК АСМ_МодификацииКомплектации
				   |ГДЕ
				   |	АСМ_МодификацииКомплектации.Ссылка.Поколение В (&Поколение)";
	ПакетОпций = Запрос.ВыполнитьПакет();

	ОпцииОтбора.Вставить("Агрегаты", ПакетОпций[0].Выгрузить());
	ОпцииОтбора.Вставить("ТипыКузовов", ПакетОпций[1].Выгрузить());
	ОпцииОтбора.Вставить("Комплектации", ПакетОпций[2].Выгрузить());

	Возврат ОпцииОтбора;

КонецФункции

// Находит элемент справочника по коду и наименованию.
// 
// Если отсутствует элемент справочника с заданным кодом и ИзменятьЭлемент = Истина - создает новый элемент
// Если наименование не соответствует заданному и ИзменятьЭлемент = Истина - производит переименование элемента
// 
// В случае неудачного поиска, создания или переименования элемента возвращает Неопределено
// 
// Параметры:
//  Код - Строка - Код
//  Наименование - Строка - Наименование
//  ИзменятьЭлемент - Булево - При необходимости изменять наименование или создавать новый элемент
//  СчетчикИзмененных - Число, Неопределено - Счетчик измененных элементов
// 
// Возвращаемое значение:
//  Неопределено, СправочникСсылка.АСМ_Марки - Найденный или созданный элемент
Функция НайтиПоКодуИНаименованию(ДанныеЗаполнения, ИзменятьЭлемент = Ложь, СчетчикИзмененных = Неопределено) Экспорт

	СправочникМенеджер = Справочники.АСМ_Поколения;

	Ссылка = АСМ_КаталогВызовСервера.НайтиСоздатьПоКодуИНаименованию(СправочникМенеджер,
																	 ДанныеЗаполнения,
																	 ИзменятьЭлемент,
																	 СчетчикИзмененных);
	Возврат Ссылка;

КонецФункции

#КонецОбласти

