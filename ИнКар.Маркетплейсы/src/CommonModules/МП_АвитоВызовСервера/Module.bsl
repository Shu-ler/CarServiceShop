Функция ИнициализироватьЗапросОстатки(Профиль)

	ЗапросОстатки = Новый Запрос;
	ЗапросОстатки.УстановитьПараметр("Склад", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Профиль, "Склад"));
	ЗапросОстатки.УстановитьПараметр("СкладОсновной", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Профиль,
																								"СкладОсновной"));
	ЗапросОстатки.Текст = "ВЫБРАТЬ
						  |	СУММА(РаспределениеЗапасов.Свободно) КАК Остаток,
						  |	РаспределениеЗапасов.Склад КАК Склад
						  |ИЗ
						  |	РегистрСведений.РаспределениеЗапасов КАК РаспределениеЗапасов
						  |ГДЕ
						  |	РаспределениеЗапасов.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОстатокНаСкладе)
						  |	И РаспределениеЗапасов.Номенклатура = &Номенклатура
						  |	И РаспределениеЗапасов.Характеристика = &Характеристика
						  |	И РаспределениеЗапасов.Склад В ИЕРАРХИИ (&Склад)
						  |	И РаспределениеЗапасов.Свободно > 0
						  |СГРУППИРОВАТЬ ПО
						  |	РаспределениеЗапасов.Склад";

	Возврат ЗапросОстатки

КонецФункции

Функция ИнициализироватьЗапросОбъявлений(Профиль)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Профиль", Профиль);
	Запрос.УстановитьПараметр("ПодкатегорииПустая", Справочники.МП_АвитоПодкатегорииТоваров.ПустаяСсылка());

	Запрос.Текст = "ВЫБРАТЬ
				   |	Объявления.Номенклатура КАК Номенклатура,
				   |	Объявления.Характеристика КАК Характеристика,
				   |	Объявления.Профиль КАК Профиль,
				   |	Объявления.ИдентификаторАвито КАК AvitoId,
				   |	Объявления.НазваниеОбъявления КАК Title,
				   |	Объявления.ДатаНачала КАК DateBegin,
				   |	Объявления.ДатаОкончания КАК DateEnd,
				   |	ПРЕДСТАВЛЕНИЕ(Объявления.ВариантПлатногоРазмещения) КАК ListingFee,
				   |	ПРЕДСТАВЛЕНИЕ(Объявления.ПлатнаяУслуга) КАК AdStatus,
				   |	Объявления.НомерТелефона КАК ContactPhone,
				   |	Объявления.Адрес КАК Address,
				   |	Объявления.КатегорияОбъявления КАК Category,
				   |	ВЫБОР
				   |		КОГДА Объявления.ПодкатегорияТовара <> &ПодкатегорииПустая
				   |			ТОГДА Объявления.ПодкатегорияТовара.Код
				   |		ИНАЧЕ """"
				   |	КОНЕЦ КАК TypeId,
				   |	ПРЕДСТАВЛЕНИЕ(Объявления.ВидОбъявления) КАК AdType,
				   |	ПРЕДСТАВЛЕНИЕ(Объявления.Состояние) КАК Condition,
				   |	ПРЕДСТАВЛЕНИЕ(Объявления.Доступность) КАК Availability,
				   |	Объявления.OEM КАК OEM,
				   |	Объявления.СтатусОбъявления КАК СтатусОбъявления,
				   |	Объявления.URLАдресОбъявления КАК URLАдресОбъявления,
				   |	Объявления.Идентификатор КАК ID,
				   |	ПРЕДСТАВЛЕНИЕ(Объявления.Номенклатура.Производитель) КАК Brand,
				   |	ПРЕДСТАВЛЕНИЕ(Объявления.Номенклатура.Описание) КАК НоменклатураОписание,
				   |	Профили.ВариантФормированияНаличия КАК ВариантФормированияНаличия,
				   |	Профили.ВидЦены КАК ВидЦены,
				   |	ПРЕДСТАВЛЕНИЕ(Профили.ВозможностьНаписатьСообщениеПоОбъявлениюЧерезСайт) КАК AllowEmail,
				   |	Профили.РазделительРазделов КАК РазделительРазделов,
				   |	Профили.Подвал КАК Подвал,
				   |	Профили.Шапка КАК Шапка,
				   |	Профили.Склад КАК Склад,
				   |	Профили.СкладОсновной КАК СкладОсновной,
				   |	Профили.Скидка КАК Скидка,
				   |	Объявления.Номенклатура.Артикул КАК НоменклатураАртикул,
				   |	Объявления.Номенклатура.ФайлКартинки КАК НоменклатураФайлКартинки,
				   |	ВЫРАЗИТЬ(ЕСТЬNULL(Цены.Цена, 0) * (100 - Профили.Скидка) / 100 КАК ЧИСЛО(15, 0)) КАК Price,
				   |	ЕСТЬNULL(ФизическиеЛица.Имя, ""Менеджер"") КАК ManagerName,
				   |	Объявления.НеПубликоватьОстатки КАК НеПубликоватьОстатки,
				   |	Профили.ИспользоватьЗоныПоказа КАК ИспользоватьЗоныПоказа
				   |ИЗ
				   |	РегистрСведений.УдалитьМП_АвитоИдентификаторыОбъявлений КАК Объявления
				   |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.МП_АвитоПрофили КАК Профили
				   |		ПО Объявления.Профиль = Профили.Ссылка
				   |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних КАК Цены
				   |		ПО Цены.Номенклатура = Объявления.Номенклатура
				   |		И Цены.Характеристика = Объявления.Характеристика
				   |		И Цены.ВидЦены = Профили.ВидЦены
				   |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
				   |		ПО Объявления.Менеджер.ФизическоеЛицо = ФизическиеЛица.Ссылка
				   |ГДЕ
				   |	Объявления.Идентификатор <> """"
				   |	И Объявления.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
				   |	И Объявления.Профиль = &Профиль";
	Возврат Запрос

КонецФункции

