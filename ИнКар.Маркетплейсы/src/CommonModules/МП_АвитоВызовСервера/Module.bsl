Функция ИнициализироватьЗапросКартинок()

	Перем ЗапросКартинок;
	ЗапросКартинок = Новый Запрос;
	ЗапросКартинок.УстановитьПараметр("ТипХраненияФайла", Перечисления.ТипыХраненияФайлов.ВТомахНаДиске);

	ЗапросКартинок.Текст = "ВЫБРАТЬ
						   |	НоменклатураПрисоединенныеФайлы.ПутьКФайлу КАК ПутьКФайлу,
						   |	НоменклатураПрисоединенныеФайлы.Том.ПолныйПутьWindows КАК Том
						   |ИЗ
						   |	Справочник.НоменклатураПрисоединенныеФайлы КАК НоменклатураПрисоединенныеФайлы
						   |ГДЕ
						   |	НоменклатураПрисоединенныеФайлы.ТипХраненияФайла = &ТипХраненияФайла
						   |	И НоменклатураПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла";
