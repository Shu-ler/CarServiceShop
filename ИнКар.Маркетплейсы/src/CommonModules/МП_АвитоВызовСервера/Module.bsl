//  ТекстОбъявления - Массив - Текст объявления
Процедура ВставитьКонецСписка(ТекстОбъявления)

	ТегиHTML = МП_КонстантыКлиентСерверПовтИсп.ТегиHTML();

	ТекстОбъявления.Добавить(ТегиHTML.ЮлК);
