#Область СлужебныйПрограммныйИнтерфейс

// Проверка ответа сайта на соответствие коду 200
// 
// Параметры:
//  ОтветСайта - Структура, Неопределено - Ответ сайта:
// * КодСостояния - Число - Код состояния
// * ТелоОтвета - Произвольный - Тело ответа
// 
// Возвращаемое значение:
//  Булево - Сайт вернул "200"
Функция ОтветСайтаОк(ОтветСайта)
	Возврат ОтветСайта <> Неопределено
			И ОтветСайта.КодСостояния = 200
			И ТипЗнч(ОтветСайта.ТелоОтвета) = Тип("Структура");
КонецФункции

// Возвращает URI API Авито
// 
// Возвращаемое значение:
//  Строка - Адрес сайта
Функция АдресСайта() Экспорт
	Возврат "https://api.avito.ru";
КонецФункции

// Возвращает ключ токена
// 
// Возвращаемое значение:
//  Строка - Ключ токена
Функция КлючТокена() Экспорт
	Возврат "access_token";
КонецФункции

// Возвращает заголовок авторизации на основе токена
// 
// Параметры:
//  Токен - Строка - Токен
//  Заголовки - Неопределено, Соответствие - Заголовки запроса
// 
// Возвращаемое значение:
//  Соответствие - Заголовок авторизации
Функция ЗаголовокАвторизации(Токен, Заголовки = Неопределено) Экспорт

	ЗаголовокAuthorization = "Authorization";
	ЗаголовокAuthorizationШаблон = "Bearer %1";

	// Если не указан параметр Заголовки - создаем новое соответствие для заголовков, если указан - добавляем 
	// к существующему
	Если Заголовки = Неопределено Тогда
		Заголовки = Новый Соответствие;
	КонецЕсли;

	Заголовки.Вставить(ЗаголовокAuthorization, СтрШаблон(ЗаголовокAuthorizationШаблон, Токен));

	Возврат Заголовки

КонецФункции

#КонецОбласти