Функция КоллекцияМоделейDOM(Номенклатура, Характеристика, ДокументDOM)

	КоллекцияМоделей = ДокументDOM.СоздатьЭлемент("cars");

	Модели = Новый Массив;
	Выполнить ("Справочники.КА2_КлючиМоделей.НайтиПоНоменклатуреДляДром(Номенклатура, Характеристика, Модели)");

	Если Модели.Количество() > 0 Тогда

		Для Каждого Эл Из Модели Цикл

			Модель = ДокументDOM.СоздатьЭлемент("car");

			Для Каждого Ключ Из Эл Цикл
				Если Не ПустаяСтрока(Ключ.Значение) Тогда
					МодельУзел = ДокументDOM.СоздатьЭлемент(Ключ.Ключ);
					МодельУзел.ТекстовоеСодержимое = Ключ.Значение;
					Модель.ДобавитьДочерний(МодельУзел);
				КонецЕсли;
			КонецЦикла;

			КоллекцияМоделей.ДобавитьДочерний(Модель);

		КонецЦикла;

	КонецЕсли;

	Возврат КоллекцияМоделей;

КонецФункции

Функция ИнициализироватьДокументDOM(ПараметрыПрофиля, СписокПредложений, ОписаниеМагазина, КорневойУзел)

	Перем СписокВалют;
	Перем ДатаВремя;
	Перем СписокКатегорий;
	Перем Валюта;

	ВидМаркетплейса = ПараметрыПрофиля.ВидМаркетплейса;

	// Получение имени корневого элемента
	ИмяКорневогоЭлемента = ?(ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.ДРОМ,
							 "offers",
							 ?(ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.Avito, "Ads", "yml_catalog"));
	
	// Создание документа DOM
	ДокDOM = Новый ДокументDOM(ПространствоИменДром(), ИмяКорневогоЭлемента);
	
	// Узлы вне коллекции объявлений и атрибуты документов
	Если ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.Avito Тогда

		ДокDOM.ЭлементДокумента.УстановитьАтрибут("formatVersion", "3");
		ДокDOM.ЭлементДокумента.УстановитьАтрибут("target", "Avito.ru");

	КонецЕсли;

	Если ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.VK
		 Или ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.ДубльГис Тогда
		
		// Установка атрибутов корневого узла
		КорневойУзел = ДокDOM.ДочерниеУзлы.Элемент(0);
		ДатаВремя = Формат(ТекущаяДатаСеанса(), "ДФ='yyyy-MM-dd HH:mm'");
		КорневойУзел.УстановитьАтрибут("date", ДатаВремя);
	
		// Формирование узла описания магазина			
		ОписаниеМагазина = ДокDOM.СоздатьЭлемент("shop");

		СоздатьДочернийЭлемент("name", ОписаниеМагазина, ПараметрыПрофиля.Shop_name, ДокDOM);
		СоздатьДочернийЭлемент("company", ОписаниеМагазина, ПараметрыПрофиля.Shop_company, ДокDOM);
		СоздатьДочернийЭлемент("url", ОписаниеМагазина, ПараметрыПрофиля.Shop_url, ДокDOM);
		СоздатьДочернийЭлемент("email", ОписаниеМагазина, ПараметрыПрофиля.Shop_email, ДокDOM);

		// Описание магазина - узел <currencies>
		Валюта = ДокDOM.СоздатьЭлемент("currency");
		Валюта.УстановитьАтрибут("id", "RUR");
		Валюта.УстановитьАтрибут("rate", "1");

		СписокВалют = ДокDOM.СоздатьЭлемент("currencies");
		СписокВалют.ДобавитьДочерний(Валюта);
	
		// Описание магазина - секция categories
		СписокКатегорий = РегистрыСведений.МП_КатегорииYML.РазделКатегорииМагазина(ДокDOM);
 
		// Формирование узла описания магазина			
		ОписаниеМагазина.ДобавитьДочерний(СписокВалют);
		ОписаниеМагазина.ДобавитьДочерний(СписокКатегорий);

		СписокПредложений = ДокDOM.СоздатьЭлемент("offers");

	КонецЕсли;

	Если ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.Юла Тогда
		
		// Установка атрибутов корневого узла
		КорневойУзел = ДокDOM.ДочерниеУзлы.Элемент(0);
		ДатаВремя = Формат(ТекущаяДатаСеанса(), "ДФ='yyyy-MM-dd HH:mm'");
		КорневойУзел.УстановитьАтрибут("date", ДатаВремя);
	
		// Формирование узла описания магазина			
		ОписаниеМагазина = ДокDOM.СоздатьЭлемент("shop");

		СписокПредложений = ДокDOM.СоздатьЭлемент("offers");

		КорневойУзел.ДобавитьДочерний(ОписаниеМагазина);
		ОписаниеМагазина.ДобавитьДочерний(СписокПредложений);

	КонецЕсли;

	Возврат ДокDOM;

КонецФункции

#КонецОбласти

#КонецОбласти