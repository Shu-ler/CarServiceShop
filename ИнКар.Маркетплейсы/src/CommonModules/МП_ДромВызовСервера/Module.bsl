Процедура ВставитьПрименимость(ТО, ПараметрыПрофиля, ОтборПоТовару, НаборМоделей, ВидМаркетплейса)

	Перем Модели;
	Перем СтрокаМодель;

	Если ВидМаркетплейса.ЭтоДРОМ Тогда
		Возврат;
	КонецЕсли;

	ТегиHTML = МП_КонстантыКлиентСерверПовтИсп.ТегиHTML();

	Модели = Новый Массив;
	Пока НаборМоделей.НайтиСледующий(ОтборПоТовару) Цикл
		Модели.Добавить(НаборМоделей.КлючМодели);
	КонецЦикла;

	НаборМоделей.Сбросить();

	Если Модели.Количество() > 0 Тогда

		Если ВидМаркетплейса.ЭтоВК Или ВидМаркетплейса.ЭтоЮла Или ВидМаркетплейса.Это2ГИС Тогда

			ТО.Добавить("Подходит для следующих моделей автомобилей:");
			ТО.Добавить(Символы.ПС);

			Для Каждого Элемент Из Модели Цикл
				СтрокаМодель = СтрШаблон("  - %1", Элемент);
				ТО.Добавить(СтрокаМодель);
				ТО.Добавить(Символы.ПС);
			КонецЦикла;

		ИначеЕсли ВидМаркетплейса.ЭтоAVITO Тогда

			ТО.Добавить(ПараметрыПрофиля.РазделительРазделов);
			ТО.Добавить("Подходит для следующих моделей автомобилей:");
			ТО.Добавить(Символы.ПС);

			ТО.Добавить(ТегиHTML.Юл);
			Для Каждого Элемент Из Модели Цикл
				СтрокаМодель = СтрШаблон("%1%2", ТегиHTML.Ли, Элемент);
				ТО.Добавить(СтрокаМодель);
			КонецЦикла;
			ТО.Добавить(ТегиHTML.ЮлК);

		КонецЕсли;

	КонецЕсли;

	НаборМоделей.Сбросить();

КонецПроцедуры

Функция ВставитьОстатки(ТО, ПараметрыПрофиля, ОтборПоТовару, Остатки, ВидМаркетплейса)

	ТегиHTML = МП_КонстантыКлиентСерверПовтИсп.ТегиHTML();

	СкладыСОстатками = Новый СписокЗначений;

	Пока Остатки.НайтиСледующий(ОтборПоТовару) Цикл
		Если СтрНайти(Остатки.СкладAvito, "()") = 0 Тогда
			СкладЗначение = СтрЗаменить(Остатки.СкладAvito, " г)", ")");
			СкладыСОстатками.Добавить(СкладЗначение, Остатки.Свободно);
		КонецЕсли;
	КонецЦикла;

	Остатки.Сбросить();

	ТО.Добавить(ПараметрыПрофиля.РазделительРазделов);

	Если СкладыСОстатками.Количество() > 0 Тогда

		ТО.Добавить(ПараметрыПрофиля.НаличиеШапка);
		ТО.Добавить(ТегиHTML.Юл);

		Для Каждого Элемент Из СкладыСОстатками Цикл
			ТО.Добавить(Элемент.Значение);
		КонецЦикла;

		ТО.Добавить(ТегиHTML.ЮлК);
		ТО.Добавить(ПараметрыПрофиля.НаличиеПодвал);

		Доступность = Перечисления.МП_АвитоДоступность.ВНаличии;

	Иначе

		ТО.Добавить(ПараметрыПрофиля.СообщениеОНедоступности);
		ТО.Добавить(Символы.ПС);

		Доступность = Перечисления.МП_АвитоДоступность.ПодЗаказ;

	КонецЕсли;

	Возврат Доступность;

КонецФункции

Процедура ВставитьХарактеристики(ТО, ПараметрыПрофиля, ОтборПоТовару, ДопРеквизиты, ВидМаркетплейса)

	ЕстьХарактеристики = Ложь;

	Если ВидМаркетплейса.ЭтоAVITO Тогда

		ТегиHTML = МП_КонстантыКлиентСерверПовтИсп.ТегиHTML();

		Пока ДопРеквизиты.НайтиСледующий(ОтборПоТовару) Цикл
		
			// При необходимости добавляем заголовок списка
			Если Не ЕстьХарактеристики Тогда

				ТО.Добавить(ПараметрыПрофиля.РазделительРазделов);
				ТО.Добавить("Характеристики товара:");
				ТО.Добавить(ТегиHTML.Юл);

				ЕстьХарактеристики = Истина;

			КонецЕсли;

			ТО.Добавить(ТегиHTML.Ли);
			ТО.Добавить(ДопРеквизиты.Заголовок);
			ТО.Добавить(" -- ");
			ТО.Добавить(Строка(ДопРеквизиты.Значение));

		КонецЦикла;

		Если ЕстьХарактеристики Тогда
			ТО.Добавить(ТегиHTML.ЮлК);
		КонецЕсли;

	Иначе

		Пока ДопРеквизиты.НайтиСледующий(ОтборПоТовару) Цикл
		
			// При необходимости добавляем заголовок списка
			Если Не ЕстьХарактеристики Тогда

				ТО.Добавить(Символы.ПС);
				ТО.Добавить("Характеристики товара:");
				ТО.Добавить(Символы.ПС);

				ЕстьХарактеристики = Истина;

			КонецЕсли;

			ТО.Добавить(Символы.ПС);
			ТО.Добавить(ДопРеквизиты.Заголовок);
			ТО.Добавить(" -- ");
			ТО.Добавить(Строка(ДопРеквизиты.Значение));

		КонецЦикла;

		Если ЕстьХарактеристики Тогда
			ТО.Добавить(Символы.ПС);
		КонецЕсли;

	КонецЕсли;

	ДопРеквизиты.Сбросить();

КонецПроцедуры

