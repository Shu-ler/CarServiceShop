// Возвращает реквизиты профиля
// 
// Параметры:
//  Профиль - СправочникСсылка.МП_Профили - Профиль
// 
// Возвращаемое значение:
//  Структура - Реквизиты профиля
Функция РеквизитыПрофиля(Профиль)

	Реквизиты = Новый Массив;

	Реквизиты.Добавить("ВидМаркетплейса");
	Реквизиты.Добавить("URLЗагрузки");
	Реквизиты.Добавить("ПубликоватьКартинки");
	Реквизиты.Добавить("ВариантФормированияНаличия");
	Реквизиты.Добавить("СкладОсновной");
	Реквизиты.Добавить("ИмяФайлаВыгрузки");
	Реквизиты.Добавить("Шапка");
	Реквизиты.Добавить("РазделительРазделов");
	Реквизиты.Добавить("Подвал");
	Реквизиты.Добавить("Shop_name");
	Реквизиты.Добавить("Shop_company");
	Реквизиты.Добавить("Shop_url");
	Реквизиты.Добавить("Shop_email");
	Реквизиты.Добавить("РеквизитВидео");
	Реквизиты.Добавить("ТелефонПоУмолчанию");
	Реквизиты.Добавить("АдресПоУмолчанию");
	Реквизиты.Добавить("ВедущийМенеджер");
	Реквизиты.Добавить("Код");
	Реквизиты.Добавить("ИспользоватьЗоныПоказа");
	Реквизиты.Добавить("СообщениеОНедоступности");
	Реквизиты.Добавить("НаличиеШапка");
	Реквизиты.Добавить("НаличиеПодвал");

	ПараметрыПрофиля = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Профиль, Реквизиты);

	МенеджерИмя = "Менеджер";

	Если ЗначениеЗаполнено(ПараметрыПрофиля.ВедущийМенеджер) Тогда

		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Пользователь", ПараметрыПрофиля.ВедущийМенеджер);
		Запрос.Текст = "ВЫБРАТЬ
					   |	Пользователи.ФизическоеЛицо.Имя КАК ФизическоеЛицоИмя
					   |ИЗ
					   |	Справочник.Пользователи КАК Пользователи
					   |ГДЕ
					   |	Пользователи.Ссылка = &Пользователь";
		Выборка = Запрос.Выполнить().Выбрать();

		Если Выборка.Следующий() Тогда
			МенеджерИмя = Выборка.ФизическоеЛицоИмя;
		КонецЕсли;

	КонецЕсли;

	ПараметрыПрофиля.Вставить("МенеджерИмя", МенеджерИмя);

	Возврат ПараметрыПрофиля

КонецФункции

