#Область ПрограммныйИнтерфейс

#Область ПакетныеМетоды
// Методы, предназначенные для пакетной обработки обмена с сайтом Авито.
// Пригодны для запуска в качестве регламентного задания

Процедура СформироватьФайлыАвтозагрузок() Экспорт

	НаборПрофилей = Справочники.МП_Профили.ГотовыКАвтозагрузке();

	ДополнительныеПараметры = Новый Структура;

	Для Каждого Профиль Из НаборПрофилей Цикл
		СформироватьПрайс(Профиль, ДополнительныеПараметры);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область МетодыПрофилей

Функция СформироватьПрайс(Профиль, ДополнительныеПараметры) Экспорт

	СписокПредложений = Неопределено;
	КорневойУзел = Неопределено;
	ОписаниеМагазина = Неопределено;

	Счетчик = 0;

	Результат = Новый Структура("Сообщение, Ошибки");

	Если ЗначениеЗаполнено(Профиль) Тогда

		ПараметрыПрофиля = РеквизитыПрофиля(Профиль);
		ВидМаркетплейса = ПараметрыПрофиля.ВидМаркетплейса;
		ВидМаркетплейса = Новый Структура;
		
		// Флажки 
		ВидМаркетплейса.Вставить("ЭтоДРОМ", ПараметрыПрофиля.ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.ДРОМ);
		ВидМаркетплейса.Вставить("ЭтоВК", ПараметрыПрофиля.ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.VK);
		ВидМаркетплейса.Вставить("ЭтоAVITO", ПараметрыПрофиля.ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.Avito);
		ВидМаркетплейса.Вставить("ЭтоЮла", ПараметрыПрофиля.ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.Юла);
		ВидМаркетплейса.Вставить("Это2ГИС",
								 ПараметрыПрофиля.ВидМаркетплейса = Перечисления.МП_ВидыМаркетплейсов.ДубльГис);

		ПубликоватьВсеКартинки = (ПараметрыПрофиля.ПубликоватьКартинки
								  = Перечисления.МП_ВариантыПубликацииКартинок.ПубликоватьВсе);
		ПубликоватьПрименимость = (Метаданные.НайтиПоПолномуИмени("Подсистема.АвтосервисАвтомагазин") <> Неопределено);
		ПубликоватьВидео = ЗначениеЗаполнено(ПараметрыПрофиля.РеквизитВидео);
		ПубликоватьВсеОстатки = (ПараметрыПрофиля.ВариантФормированияНаличия
								 = Перечисления.МП_ВариантыФормированияНаличия.ПоГруппеСкладов);

		// Имена узлов в зависимости от вида маркетплейса
		ИмяЭлементаТекстОбъявления = ?(ВидМаркетплейса.ЭтоAVITO, "Description", "description");
		ИмяЭлементаОбъявление = ?(ВидМаркетплейса.ЭтоAVITO, "Ad", "offer");
		
		// Получение коллекций товаров и дополнительных данных для объявлений
		ДляОбъявлений = Справочники.МП_Профили.ТоварыПрофиля(Профиль);

		НаВыгрузку = ДляОбъявлений.Товары;
		ДопРеквизиты = ДляОбъявлений.Свойства;
		НаборИзображений = ДляОбъявлений.Картинки;
		НаборМоделей = ДляОбъявлений.Модели;
		Остатки = ДляОбъявлений.Остатки;

		// Подготовка счетчиков для отображения прогресса выполнения
		ВсегоОбъявлений = НаВыгрузку.Количество();
		Приращение = Окр(ВсегоОбъявлений / 100, 0);
		Приращение = ?(Приращение = 0, 1, Приращение);

		// Формирование документа DOM
		Если НаВыгрузку.Количество() > 0 Тогда

			// Получение коллекции зон показа
			ПубликоватьЗоныПоказа = ПараметрыПрофиля.ИспользоватьЗоныПоказа;

			Если ПубликоватьЗоныПоказа Тогда
				НаборЗон = Справочники.МП_Профили.ЗоныПоказа(Профиль);
			КонецЕсли;

			// Создание и инициализация документа DOM			
			ДокDOM = ИнициализироватьДокументDOM(ПараметрыПрофиля, СписокПредложений, ОписаниеМагазина, КорневойУзел);

			// Цикл формирования объявлений
			Пока НаВыгрузку.Следующий() Цикл

				ОтборПоТовару = Новый Структура("Номенклатура, Характеристика",
												НаВыгрузку.Номенклатура,
												НаВыгрузку.Характеристика);
				// Создание объявления
				ОбъявлениеDOM = ДокDOM.СоздатьЭлемент(ИмяЭлементаОбъявление);

				// Заполнение узлов в зависимости от вида маркетплейса
				Если ВидМаркетплейса.ЭтоВК Или ВидМаркетплейса.Это2ГИС Тогда
					СоздатьУзлыВК(НаВыгрузку, ОбъявлениеDOM, ДокDOM);
				ИначеЕсли ВидМаркетплейса.ЭтоДРОМ Тогда
					СоздатьУзлыДРОМ(НаВыгрузку, ОбъявлениеDOM, ДокDOM);
				ИначеЕсли ВидМаркетплейса.ЭтоAVITO Тогда
					СоздатьУзлыAVITO(НаВыгрузку, ПараметрыПрофиля, ОбъявлениеDOM, ДокDOM);
				ИначеЕсли ВидМаркетплейса.ЭтоЮла Тогда
					СоздатьУзлыЮла(НаВыгрузку, ПараметрыПрофиля, ОбъявлениеDOM, ДокDOM);
				ИначеЕсли ВидМаркетплейса.Это2ГИС Тогда
					СоздатьУзлы2ГИС(НаВыгрузку, ПараметрыПрофиля, ОбъявлениеDOM, ДокDOM);
				КонецЕсли;				
				
				// Формирование текста объявления
				ТО = Новый Массив;

				ВставитьШапку(ТО, ПараметрыПрофиля, ВидМаркетплейса);
				ВставитьНаименованиеНоменклатуры(ТО, НаВыгрузку, ВидМаркетплейса);
				ВставитьОписаниеНоменклатуры(ТО, НаВыгрузку);

				Если ПубликоватьПрименимость Тогда
					ВставитьПрименимость(ТО, ПараметрыПрофиля, ОтборПоТовару, НаборМоделей, ВидМаркетплейса);
				КонецЕсли;

				Если ПубликоватьВсеОстатки И ВидМаркетплейса.ЭтоAVITO Тогда
					Доступность = ВставитьОстатки(ТО, ПараметрыПрофиля, ОтборПоТовару, Остатки, ВидМаркетплейса);
					СоздатьДочернийЭлемент("Availability", ОбъявлениеDOM, Строка(Доступность), ДокDOM);
				КонецЕсли;

				ВставитьХарактеристики(ТО, ПараметрыПрофиля, ОтборПоТовару, ДопРеквизиты, ВидМаркетплейса);
				ВставитьПодвал(ТО, ПараметрыПрофиля, ВидМаркетплейса);
				
				// Узел <Description>
				ТекстОбъявления = СтрСоединить(ТО);

				Если СтрДлина(ТекстОбъявления) > 0 Тогда
					Элемент = ДокDOM.СоздатьЭлемент(ИмяЭлементаТекстОбъявления);
					Если ВидМаркетплейса.ЭтоAVITO Тогда
						Секция = ДокDOM.СоздатьСекциюCDATA(ТекстОбъявления);
						Элемент.ДобавитьДочерний(Секция);
					Иначе
						Элемент.ТекстовоеСодержимое = ТекстОбъявления;
					КонецЕсли;
					ОбъявлениеDOM.ДобавитьДочерний(Элемент);
				КонецЕсли;
						
				// Секция картинок
				Если ПубликоватьВсеКартинки Тогда
					СоздатьУзлыКартинок(ДокDOM,
										ОбъявлениеDOM,
										ВидМаркетплейса,
										ОтборПоТовару,
										НаборИзображений,
										ПараметрыПрофиля.URLЗагрузки);
				КонецЕсли;
	
				// Добавление видео
				Если ПубликоватьВидео Тогда
					ВставитьУзелВидео(ДокDOM, ОбъявлениеDOM, НаВыгрузку, ПараметрыПрофиля);
				КонецЕсли;
	
				// Добавление зон показа
				Если ПубликоватьЗоныПоказа Тогда
					СоздатьУзелЗоныПоказа(ДокDOM, ОбъявлениеDOM, НаборЗон);
				КонецЕсли;
	
				// Секция применимость
				Если ПубликоватьПрименимость И ВидМаркетплейса.ЭтоДРОМ Тогда

					КоллекцияМоделей = КоллекцияМоделейDOM(НаВыгрузку.Номенклатура, НаВыгрузку.Характеристика, ДокDOM);

					Если КоллекцияМоделей.ЕстьДочерниеУзлы() Тогда
						ОбъявлениеDOM.ДобавитьДочерний(КоллекцияМоделей);
					КонецЕсли;

				КонецЕсли;

				// Добавление объявления в документ
				ВставитьОбъявлениеВДокумент(ВидМаркетплейса, СписокПредложений, ДокDOM, ОбъявлениеDOM);

				Счетчик = Счетчик + 1;

				Если Счетчик % Приращение = 0 Тогда
					ТекстСообщения = СтрШаблон("Обработано %1 из %2 объявлений", Счетчик, ВсегоОбъявлений);
					ДлительныеОперации.СообщитьПрогресс(Формат(Счетчик / ВсегоОбъявлений * 100, "ЧДЦ=2;"),
														ТекстСообщения);
				КонецЕсли;

			КонецЦикла;

			Если ВидМаркетплейса.ЭтоВК Или ВидМаркетплейса.Это2ГИС Тогда
				
				// Добавление списка предложений в описание магазина
				ОписаниеМагазина.ДобавитьДочерний(СписокПредложений);
				
				// Добавление магазина в DOM
				КорневойУзел.ДобавитьДочерний(ОписаниеМагазина);

			КонецЕсли;
			
			// Сохранение ДокументDOM в файл
			Если ДокDOM.ЕстьДочерниеУзлы() Тогда
				МП_УниверсальныеМетодыВызовСервера.СохранитьДокументDOMВФайле(ДокDOM,
																			  ПараметрыПрофиля.ИмяФайлаВыгрузки,
																			  ПространствоИменДром());
				ЗафиксироватьВРегистре(Профиль, Счетчик);

			КонецЕсли;

		КонецЕсли;

	Иначе
		Результат.Вставить("Ошибки", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Не задан профиль"));
	КонецЕсли;

	Возврат Результат;

КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область УзлыФайловОбъявлений

Процедура СоздатьУзлыВК(НаВыгрузку, ОбъявлениеDOM, ДокDOM)

	ОбъявлениеDOM.УстановитьАтрибут("id", НаВыгрузку.Код);
	СоздатьДочернийЭлемент("name", ОбъявлениеDOM, НаВыгрузку.НоменклатураНаименование, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("vendor", ОбъявлениеDOM, НаВыгрузку.Производитель, ДокDOM);
	СоздатьДочернийЭлемент("vendorCode", ОбъявлениеDOM, НаВыгрузку.Артикул, ДокDOM);
	СоздатьДочернийЭлемент("price", ОбъявлениеDOM, НаВыгрузку.ЦенаСоСкидкой, ДокDOM, Истина);
	СоздатьДочернийЭлемент("store", ОбъявлениеDOM, "true", ДокDOM);

КонецПроцедуры

Процедура СоздатьУзлыЮла(НаВыгрузку, ПараметрыПрофиля, ОбъявлениеDOM, ДокDOM)

	Перем Название;

	ОбъявлениеDOM.УстановитьАтрибут("id", НаВыгрузку.Код);

	СоздатьКраткоеНазваниеОбъявления(НаВыгрузку, Название);

	СоздатьДочернийЭлемент("name", ОбъявлениеDOM, Название.НазваниеОбъявления, ДокDOM);

	СоздатьДочернийЭлементСПроверкой("youlaCategoryId", ОбъявлениеDOM, НаВыгрузку.ЮлаКатегория, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("youlaSubcategoryId", ОбъявлениеDOM, НаВыгрузку.ЮлаПодкатегория, ДокDOM);

	Если Не ПустаяСтрока(НаВыгрузку.ЮлаТегПодкатегории) И Не ПустаяСтрока(НаВыгрузку.ЮлаТипДетали) Тогда
		СоздатьДочернийЭлемент(НаВыгрузку.ЮлаТегПодкатегории, ОбъявлениеDOM, НаВыгрузку.ЮлаТипДетали, ДокDOM);
	КонецЕсли;

	СоздатьДочернийЭлементСПроверкой("kuzovnaya_detal", ОбъявлениеDOM, НаВыгрузку.ЮлаГруппаДеталей, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("chast_detali", ОбъявлениеDOM, НаВыгрузку.ЮлаНазваниеДетали, ДокDOM);

	СоздатьДочернийЭлемент("price", ОбъявлениеDOM, НаВыгрузку.ЦенаСоСкидкой, ДокDOM, Истина);
	СоздатьДочернийЭлемент("phone", ОбъявлениеDOM, ПараметрыПрофиля.ТелефонПоУмолчанию, ДокDOM);
	СоздатьДочернийЭлемент("address", ОбъявлениеDOM, ПараметрыПрофиля.АдресПоУмолчанию, ДокDOM);
	СоздатьДочернийЭлемент("managerName", ОбъявлениеDOM, ПараметрыПрофиля.МенеджерИмя, ДокDOM);

КонецПроцедуры

Процедура СоздатьУзлыДРОМ(НаВыгрузку, ОбъявлениеDOM, ДокDOM)

	СоздатьДочернийЭлемент("name", ОбъявлениеDOM, НаВыгрузку.НоменклатураНаименованиеПолное, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("manufacturer", ОбъявлениеDOM, НаВыгрузку.Производитель, ДокDOM);
	СоздатьДочернийЭлемент("ordercode", ОбъявлениеDOM, НаВыгрузку.Артикул, ДокDOM);
	СоздатьДочернийЭлемент("condition", ОбъявлениеDOM, НаВыгрузку.condition, ДокDOM);
	СоздатьДочернийЭлемент("price", ОбъявлениеDOM, НаВыгрузку.ЦенаСоСкидкой, ДокDOM, Истина);
	СоздатьДочернийЭлемент("currencyId", ОбъявлениеDOM, НаВыгрузку.currencyId, ДокDOM);
	СоздатьДочернийЭлемент("status", ОбъявлениеDOM, НаВыгрузку.status, ДокDOM);

КонецПроцедуры

Процедура СоздатьУзлыAVITO(НаВыгрузку, ПараметрыПрофиля, ОбъявлениеDOM, ДокDOM)

	Перем Название;
	Перем ID;

	ID = СтрШаблон("%1$%2$БезХарактеристики", ПараметрыПрофиля.Код, НаВыгрузку.Код);

	СоздатьКраткоеНазваниеОбъявления(НаВыгрузку, Название);

	СоздатьДочернийЭлемент("Title", ОбъявлениеDOM, Название.НазваниеОбъявления, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("ListingFee", ОбъявлениеDOM, НаВыгрузку.ВариантПлатногоРазмещения, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("AdStatus", ОбъявлениеDOM, НаВыгрузку.ПлатнаяУслуга, ДокDOM);
	СоздатьДочернийЭлемент("ContactPhone", ОбъявлениеDOM, ПараметрыПрофиля.ТелефонПоУмолчанию, ДокDOM);
	СоздатьДочернийЭлемент("Address", ОбъявлениеDOM, ПараметрыПрофиля.АдресПоУмолчанию, ДокDOM);
	СоздатьДочернийЭлемент("Category", ОбъявлениеDOM, "Запчасти и аксессуары", ДокDOM);
	СоздатьДочернийЭлемент("TypeId", ОбъявлениеDOM, НаВыгрузку.TypeidAvito, ДокDOM);
		// TODO: Сделать возможность публиковать объявления на своё производство
	СоздатьДочернийЭлемент("AdType", ОбъявлениеDOM, "Товар приобретен на продажу", ДокDOM);
		// TODO: Сделать возможность публиковать объявления на б/у
	СоздатьДочернийЭлемент("Condition", ОбъявлениеDOM, "Новое", ДокDOM);
	СоздатьДочернийЭлемент("ID", ОбъявлениеDOM, ID, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("Brand", ОбъявлениеDOM, НаВыгрузку.Производитель, ДокDOM);
	СоздатьДочернийЭлемент("AllowEmail", ОбъявлениеDOM, "Да", ДокDOM);
	СоздатьДочернийЭлемент("Price", ОбъявлениеDOM, НаВыгрузку.ЦенаСоСкидкой, ДокDOM, Истина);
	СоздатьДочернийЭлемент("ManagerName", ОбъявлениеDOM, ПараметрыПрофиля.МенеджерИмя, ДокDOM);
//	<DateEnd>2079-08-28</DateEnd>
	СоздатьДочернийЭлемент("DateEnd", ОбъявлениеDOM, "2023-01-01", ДокDOM);

КонецПроцедуры

Процедура СоздатьУзлы2ГИС(НаВыгрузку, ПараметрыПрофиля, ОбъявлениеDOM, ДокDOM)

	ОбъявлениеDOM.УстановитьАтрибут("id", НаВыгрузку.Код);
	СоздатьДочернийЭлемент("name", ОбъявлениеDOM, НаВыгрузку.НоменклатураНаименование, ДокDOM);
	СоздатьДочернийЭлементСПроверкой("vendor", ОбъявлениеDOM, НаВыгрузку.Производитель, ДокDOM);
	СоздатьДочернийЭлемент("vendorCode", ОбъявлениеDOM, НаВыгрузку.Артикул, ДокDOM);
	СоздатьДочернийЭлемент("price", ОбъявлениеDOM, НаВыгрузку.ЦенаСоСкидкой, ДокDOM, Истина);
	СоздатьДочернийЭлемент("store", ОбъявлениеDOM, "true", ДокDOM);

КонецПроцедуры

Процедура СоздатьУзлыКартинок(ДокDOM, ОбъявлениеDOM, ВидМаркетплейса, ОтборПоТовару, НаборИзображений, URLЗагрузки)

	Перем КоллекцияИзображений;
	Перем Изображение;
	Перем URLИзображения;
	
	// Имена узлов в зависимости от вида маркетплейса
	ИмяКоллекцииИзображений = ?(ВидМаркетплейса.ЭтоAVITO, "Images", "pictures");
	ИмяЭлементаИзображений = ?(ВидМаркетплейса.ЭтоAVITO, "Image", "picture");

	Если ВидМаркетплейса.ЭтоВК Или ВидМаркетплейса.ЭтоЮла  Или ВидМаркетплейса.Это2ГИС Тогда

		Пока НаборИзображений.НайтиСледующий(ОтборПоТовару) Цикл

			URLИзображения = URLЗагрузки + НаборИзображений.ПутьКФайлу;
			СоздатьДочернийЭлемент(ИмяЭлементаИзображений, ОбъявлениеDOM, URLИзображения, ДокDOM);

		КонецЦикла;

	ИначеЕсли ВидМаркетплейса.ЭтоAVITO Тогда

		КоллекцияИзображений = ДокDOM.СоздатьЭлемент(ИмяКоллекцииИзображений);

		Пока НаборИзображений.НайтиСледующий(ОтборПоТовару) Цикл

			URLИзображения = URLЗагрузки + НаборИзображений.ПутьКФайлу;
			Изображение = ДокDOM.СоздатьЭлемент(ИмяЭлементаИзображений);
			Изображение.УстановитьАтрибут("url", URLИзображения);
			КоллекцияИзображений.ДобавитьДочерний(Изображение);

		КонецЦикла;

		Если КоллекцияИзображений.ЕстьДочерниеУзлы() Тогда
			ОбъявлениеDOM.ДобавитьДочерний(КоллекцияИзображений);
		КонецЕсли;

	ИначеЕсли ВидМаркетплейса.ЭтоДРОМ Тогда

		КоллекцияИзображений = ДокDOM.СоздатьЭлемент(ИмяКоллекцииИзображений);

		Пока НаборИзображений.НайтиСледующий(ОтборПоТовару) Цикл

			URLИзображения = URLЗагрузки + НаборИзображений.ПутьКФайлу;
			Изображение = ДокDOM.СоздатьЭлемент(ИмяЭлементаИзображений);
			Изображение.ТекстовоеСодержимое = URLИзображения;
			КоллекцияИзображений.ДобавитьДочерний(Изображение);

		КонецЦикла;

		Если КоллекцияИзображений.ЕстьДочерниеУзлы() Тогда
			ОбъявлениеDOM.ДобавитьДочерний(КоллекцияИзображений);
		КонецЕсли;

	КонецЕсли;

	НаборИзображений.Сбросить();

КонецПроцедуры

Процедура СоздатьУзелЗоныПоказа(ДокDOM, ОбъявлениеDOM, НаборЗон)

	Перем ЗоныПоказаСписок;
	Перем Зона;

	ЗоныПоказаСписок = ДокDOM.СоздатьЭлемент("DisplayAreas");

	Для Каждого Зона Из НаборЗон Цикл
		СоздатьДочернийЭлемент("Area", ЗоныПоказаСписок, Зона, ДокDOM);
	КонецЦикла;

	ОбъявлениеDOM.ДобавитьДочерний(ЗоныПоказаСписок);

КонецПроцедуры

Процедура ВставитьУзелВидео(ДокDOM, ОбъявлениеDOM, НаВыгрузку, ПараметрыПрофиля)

	Перем РеквизитПолноеНаименование;
