Процедура СоздатьДочернийЭлемент(Имя, Родитель, Значение, ДокументDOM, ЦелоеЧисло = Ложь)

	ЗначениеСтрока = ?(ЦелоеЧисло, Формат(Значение, "ЧДЦ=0; ЧГ=0;"), ?(ТипЗнч(Значение) = Тип("Строка"),
																	   Значение,
																	   Строка(Значение)));

	Элемент = ДокументDOM.СоздатьЭлемент(Имя);
	Элемент.ТекстовоеСодержимое = ЗначениеСтрока;
	Родитель.ДобавитьДочерний(Элемент);

