#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьОбъявленияПоАвито(Команда)

	Если ЗначениеЗаполнено(Профиль) Тогда
		ДлительнаяОперация = НачатьОбновлениеОбъявленийПоАвито(УникальныйИдентификатор, Профиль);

		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;

		// Подключение обработчика завершения фонового задания.
		ОбработкаЗавершения = Новый ОписаниеОповещения("ПриЗавершенииОбновленияОбъявленийПоАвито", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОбработкаЗавершения, ПараметрыОжидания);

	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не выбран профиль'"),, "ОтборПрофиль");
	КонецЕсли;

КонецПроцедуры
&НаКлиенте
Процедура СформироватьФайлАвтозагрузки(Команда)

	// Параметры ожидания для фоновых обработок
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;
	ПараметрыОжидания.ВыводитьСообщения = Истина;

	// Обработка завершения
	ДополнительныеПараметры = Новый Структура("ИмяОбработки", "НачатьФормированиеАвтозагрузки");
	ОбработкаЗавершения = Новый ОписаниеОповещения("ПриЗавершенииФормированиеАвтозагрузки",
												   ЭтотОбъект,
												   ДополнительныеПараметры);
	
	// Удаление передач товаров 
	ДлительнаяОперация = НачатьФормированиеАвтозагрузки(УникальныйИдентификатор, Профиль, ДополнительныеПараметры);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОбработкаЗавершения, ПараметрыОжидания);

//	ПакетАвито = МП_АвитоВызовСервера.СформироватьФайлАвтозагрузкиПрофиля(Профиль);
//
//	ОбщегоНазначенияКлиент.СообщитьПользователю(ПакетАвито);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтатусыОбъявлений(Команда)

	Если ЗначениеЗаполнено(Профиль) Тогда
		ДлительнаяОперация = НачатьОбновлениеСтатусовОбъявлений(УникальныйИдентификатор, Профиль);

		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;

		// Подключение обработчика завершения фонового задания.
		ОбработкаЗавершения = Новый ОписаниеОповещения("ПриЗавершенииОбновленияСтатусовОбъявления", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОбработкаЗавершения, ПараметрыОжидания);

	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не выбран профиль'"),, "ОтборПрофиль");
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьОтборРавноПоИмени(ИмяПоля)

	ПравоеЗначение = ЭтаФорма[ИмяПоля];
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,
																			ИмяПоля,
																			ПравоеЗначение,
																			ВидСравненияКомпоновкиДанных.Равно,
																			,
																			ЗначениеЗаполнено(ПравоеЗначение));

КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборПоУправление()

	ИспользоватьОтбор = Не (Управление = "Все" Или ПустаяСтрока(Управление));

	ВидСравненияДляСписка = ?(Управление = "Автозагрузка",
							  ВидСравненияКомпоновкиДанных.Заполнено,
							  ВидСравненияКомпоновкиДанных.НеЗаполнено);

	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список,
																			"Номенклатура",
																			ОбщийСтатусОбработкиОбъявления,
																			ВидСравненияДляСписка,
																			,
																			ИспользоватьОтбор);
КонецПроцедуры

