&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Список выбора для СтатусРазмещенияНаСайте
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	МП_АвитоИдентификаторыОбъявлений.СтатусРазмещенияНаСайте КАК Статус
				   |ИЗ
				   |	РегистрСведений.МП_АвитоИдентификаторыОбъявлений КАК МП_АвитоИдентификаторыОбъявлений
				   |УПОРЯДОЧИТЬ ПО
				   |	Статус";
	ТЗНаборСтатусов = Запрос.Выполнить().Выгрузить();
	НаборСтатусов = ТЗНаборСтатусов.ВыгрузитьКолонку("Статус");

	Элементы.СтатусРазмещенияНаСайте1.СписокВыбора.ЗагрузитьЗначения(НаборСтатусов);

	// Список выбора для СтатусРазмещенияНаСайте
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
				   |	МП_АвитоИдентификаторыОбъявлений.ОбщийСтатусОбработкиОбъявления КАК Статус
				   |ИЗ
				   |	РегистрСведений.МП_АвитоИдентификаторыОбъявлений КАК МП_АвитоИдентификаторыОбъявлений
				   |УПОРЯДОЧИТЬ ПО
				   |	Статус";
	ТЗНаборСтатусов = Запрос.Выполнить().Выгрузить();
	НаборСтатусов = ТЗНаборСтатусов.ВыгрузитьКолонку("Статус");

	Элементы.ОтборОбщийСтатусОбработкиОбъявления.СписокВыбора.ЗагрузитьЗначения(НаборСтатусов);

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	Если ЗначениеЗаполнено(Профиль) Тогда
		
		// Заполнение статуса профиля
		ЗаполнитьСтатусыПрофиля();
		УстановитьОтборРавноПоИмени(Элементы.Профиль.Имя);

	КонецЕсли;

	УстановитьОтборРавноПоИмени(Элементы.Менеджер.Имя);
	УстановитьОтборРавноПоИмени(Элементы.СтатусРазмещенияНаСайте.Имя);
	УстановитьОтборРавноПоИмени(Элементы.ОбщийСтатусОбработкиОбъявления.Имя);
	УстановитьОтборПоУправление();

	ПриоритетПоАвито = Истина;

КонецПроцедуры

&НаКлиенте
Процедура УправлениеПриИзменении(Элемент)
	УстановитьОтборПоУправление();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОтборПрофильПриИзменении(Элемент)
	ЗаполнитьСтатусыПрофиля();
	УстановитьОтборРавноПоИмени(Элементы.Профиль.Имя);
КонецПроцедуры

