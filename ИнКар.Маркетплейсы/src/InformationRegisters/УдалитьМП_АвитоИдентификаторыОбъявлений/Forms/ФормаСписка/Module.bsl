&НаСервереБезКонтекста
Процедура ОчиститьСтатусыОбъявлений(Профиль)

	НаборЗаписей = РегистрыСведений.УдалитьМП_АвитоИдентификаторыОбъявлений.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Профиль.Установить(Профиль, Истина);
	НаборЗаписей.Прочитать();

	Для Каждого Элемент Из НаборЗаписей Цикл
		Элемент.СтатусОбъявления = "";
	КонецЦикла;

	НаборЗаписей.Записать();

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбъединитьСЗаписьюРегистра(Элемент, Профиль, ПриоритетПоАвито = Ложь)

	ПоУмолчанию = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Профиль,
															 "ТелефонПоУмолчанию,АдресПоУмолчанию,ВедущийМенеджер");

	НаборЗаписей = РегистрыСведений.УдалитьМП_АвитоИдентификаторыОбъявлений.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ИдентификаторАвито.Установить(Элемент.id, Истина);
	НаборЗаписей.Прочитать();

	Если НаборЗаписей.Количество() > 0 Тогда
		Для Каждого Эл Из НаборЗаписей Цикл

			Если ПриоритетПоАвито Тогда
				Эл.Профиль = Профиль;
				Эл.ВидОбъявления = Перечисления.МП_АвитоВидыОбъявлений.ТоварПриобретенНаПродажу;
				Эл.Состояние = Перечисления.МП_АвитоСостояние.Новое;
				Эл.НазваниеОбъявления = Элемент.title;
				Эл.ВариантПлатногоРазмещения = Перечисления.МП_АвитоВариантыПлатногоРазмещения.Package;
				Эл.ПлатнаяУслуга = Справочники.МП_АвитоПлатныеУслуги.НайтиПоКоду("Free");
				Эл.Адрес = ПоУмолчанию.АдресПоУмолчанию;
				Эл.НомерТелефона = ПоУмолчанию.ТелефонПоУмолчанию;
				Эл.Менеджер = ПоУмолчанию.ВедущийМенеджер;
				Эл.КатегорияОбъявления = "Запчасти и аксессуары";
			КонецЕсли;

			Эл.СтатусОбъявления = Элемент.status;
			Эл.URLАдресОбъявления = Элемент.url;

		КонецЦикла;
	Иначе
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Профиль = Профиль;
		НоваяЗапись.ИдентификаторАвито = Элемент.id;
		НоваяЗапись.НазваниеОбъявления = Элемент.title;
		НоваяЗапись.КатегорияОбъявления = Элемент.category.name;
		НоваяЗапись.СтатусОбъявления = Элемент.status;
		НоваяЗапись.URLАдресОбъявления = Элемент.url;
		НоваяЗапись.Адрес = ПоУмолчанию.АдресПоУмолчанию;
		НоваяЗапись.Менеджер = ПоУмолчанию.ВедущийМенеджер;
		НоваяЗапись.НомерТелефона = ПоУмолчанию.ТелефонПоУмолчанию;
		НоваяЗапись.КатегорияОбъявления = "Запчасти и аксессуары";
		НоваяЗапись.Состояние = Перечисления.МП_АвитоСостояние.Новое;
		НоваяЗапись.ВариантПлатногоРазмещения = Перечисления.МП_АвитоВариантыПлатногоРазмещения.Package;
		НоваяЗапись.ПлатнаяУслуга = Справочники.МП_АвитоПлатныеУслуги.НайтиПоКоду("Free");

		НоваяЗапись.Период = ТекущаяДатаСеанса();
	КонецЕсли;

	НаборЗаписей.Записать(Истина);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтатусыПрофиля()

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Профиль", Профиль);
	Запрос.Текст = "ВЫБРАТЬ
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.НомерОтчета,
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.ВремяОкончанияВыгрузкиОбъявленийНаСайт,
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.ВремяСозданияОтчета,
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.НазваниеОрганизации,
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.ВремяГенерацииДанногоОтчета,
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.ОбщийСтатусВыгрузки,
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.ВерсияФорматаОтчета
				   |ИЗ
				   |	РегистрСведений.МП_АвитоСтатусыЗагрузок.СрезПоследних КАК МП_АвитоСтатусыЗагрузокСрезПоследних
				   |ГДЕ
				   |	МП_АвитоСтатусыЗагрузокСрезПоследних.Профиль = &Профиль";

	Статусы = Запрос.Выполнить().Выбрать();

	Если Статусы.Следующий() Тогда
		НомерОтчета = Статусы.НомерОтчета;
		ВремяОкончанияВыгрузкиОбъявленийНаСайт = Статусы.ВремяОкончанияВыгрузкиОбъявленийНаСайт;
		ВремяСозданияОтчета = Статусы.ВремяСозданияОтчета;
		НазваниеОрганизации = Статусы.НазваниеОрганизации;
		ВремяГенерацииДанногоОтчета = Статусы.ВремяГенерацииДанногоОтчета;
		ОбщийСтатусВыгрузки = Статусы.ОбщийСтатусВыгрузки;
		ВерсияФорматаОтчета = Статусы.ВерсияФорматаОтчета;
	Иначе
		ТекущаяДата = ТекущаяДатаСеанса();
		НомерОтчета = 0;
		ВремяОкончанияВыгрузкиОбъявленийНаСайт = ТекущаяДата;
		ВремяСозданияОтчета = ТекущаяДата;
		НазваниеОрганизации = "";
		ВремяГенерацииДанногоОтчета = ТекущаяДата;
		ОбщийСтатусВыгрузки = "";
		ВерсияФорматаОтчета = "";
	КонецЕсли;

КонецПроцедуры

